# ============================================================
# .gitignore — DentHCE Sistema de Historia Clínica Electrónica
# ============================================================

# === Node.js / npm ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# === Build outputs ===
dist/
build/
.next/
out/

# === Variables de entorno (NUNCA subir al repositorio) ===
.env
.env.local
.env.production
.env.staging
*.env

# === Logs ===
logs/
*.log
keycloak_logs*.txt
temp_logs.txt
*_logs*.txt

# === Artefactos de debug / despliegue (NO versionar) ===
debug_output.pdf
test.pdf
test_only_output.pdf
debug_*.pdf
aws/scripts/*.zip
testing/scripts/*.pdf

# === Imágenes de debug/capturas sueltas ===
img/error*.jpeg
img/error*.jpg
img/WhatsApp Image*.jpeg

# === Uploads (archivos binarios de pacientes - NO subir) ===
uploads/
hce-backend/uploads/

# === Compilación TypeScript ===
*.js.map
*.d.ts.map

# === NestJS específico ===
hce-backend/dist/

# === Vite / React Frontend ===
hce-frontend/dist/
hce-frontend/.vite/

# === IDEs y editores ===
.vscode/settings.json
.idea/
*.suo
*.user
*.swp
*.swo
.DS_Store
Thumbs.db

# === Docker (volúmenes y datos) ===
postgres-data/
keycloak-data/

# === Antigravity IDE (contexto local de IA — no subir) ===
.gemini/

# === Override de docker-compose para entorno local (no versionar) ===
docker-compose.override.yml

# === Certificados y llaves privadas ===
*.pem
*.key
*.cert
*.p12
*.pfx
id_rsa
id_rsa.pub

# === Archivos temporales ===
tmp/
temp/
*.tmp
*.bak

# === Archivos de documentos del análisis funcional (opcionales) ===
# Descomenta si no querés subir los .docx:
# *.docx
